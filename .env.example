# Indexer environment — copy this file to .env before running `npm start`
#
#   cp indexer/.env.example indexer/.env
#
# Full variable reference is in the root .env.example

# ── Stellar Network ────────────────────────────────────────────────────────────
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://soroban:soroban_secret@localhost:5432/soroban_explorer

# ── Indexer ────────────────────────────────────────────────────────────────────
PORT=3001
START_LEDGER=0
POLL_MS=5000
EXPLORER_CONTRACT_ID=

# ── Auth / Rate limiting (leave blank to disable) ─────────────────────────────
ADMIN_SECRET=
REDIS_URL=
