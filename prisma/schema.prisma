generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ledger {
  sequence     Int      @id
  hash         String   @unique
  closeTime    DateTime
  txCount      Int      @default(0)
  createdAt    DateTime @default(now())

  transactions Transaction[]
  events       Event[]

  @@index([sequence])
  @@index([closeTime])
}

model Contract {
  id                 String   @id @default(cuid())
  address            String   @unique
  name               String?
  description        String?
  abi                Json?
  functionSignatures Json?
  isToken            Boolean  @default(false)
  tokenSymbol        String?
  tokenName          String?
  tokenDecimals      Int?
  wasmHash           String?
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions Transaction[]
  events       Event[]
  wasmUpgrades WasmUpgradeHistory[]

  @@index([address])
}

model WasmUpgradeHistory {
  id              String   @id @default(cuid())
  contractAddress String
  previousHash    String?
  newHash         String
  ledgerSequence  Int
  ledgerCloseTime DateTime
  transactionHash String?
  createdAt       DateTime @default(now())

  contract Contract @relation(fields: [contractAddress], references: [address])

  @@index([contractAddress, ledgerSequence])
  @@index([ledgerSequence])
}

model Transaction {
  id               String   @id @default(cuid())
  hash             String   @unique
  ledgerSequence   Int
  ledgerCloseTime  DateTime
  sourceAccount    String
  contractAddress  String?
  functionName     String?
  functionArgs     Json?
  rawXdr           String
  status           String
  humanReadable    String?
  feeCharged       String?
  sorobanResources Json?
  failureReason    String?
  createdAt        DateTime @default(now())

  ledger   Ledger    @relation(fields: [ledgerSequence], references: [sequence])
  contract Contract? @relation(fields: [contractAddress], references: [address])
  events   Event[]

  @@index([hash])
  @@index([ledgerSequence])
  @@index([sourceAccount])
  @@index([contractAddress])
  @@index([status])
  @@index([contractAddress, ledgerSequence, id])
  @@index([sourceAccount, ledgerSequence, id])
  @@index([status, ledgerSequence, id])
  @@index([ledgerSequence, id])
}

model Event {
  id              String   @id @default(cuid())
  transactionHash String
  contractAddress String
  eventType       String
  topicSymbol     String?
  topics          Json
  data            Json
  decoded         Json?
  ledgerSequence  Int
  ledgerCloseTime DateTime
  createdAt       DateTime @default(now())

  ledger      Ledger      @relation(fields: [ledgerSequence], references: [sequence])
  transaction Transaction @relation(fields: [transactionHash], references: [hash])
  contract    Contract    @relation(fields: [contractAddress], references: [address])

  @@index([transactionHash])
  @@index([contractAddress])
  @@index([eventType])
  @@index([topicSymbol])
  @@index([ledgerSequence])
  @@index([contractAddress, topicSymbol])
  @@index([contractAddress, ledgerSequence, id])
  @@index([contractAddress, eventType, ledgerSequence])
}

model EventDefinition {
  id              String   @id @default(cuid())
  contractAddress String
  topicSymbol     String
  humanTemplate   String
  submittedBy     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([contractAddress, topicSymbol])
  @@index([contractAddress])
}

model SessionAuthorization {
  id                String   @id @default(cuid())
  eventId           String   @unique
  contractAddress   String
  hotSigner         String?
  authorizationType String
  startLedger       Int
  expiryLedger      Int
  allocatedBlocks   Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([contractAddress])
  @@index([expiryLedger])
}

model IndexerState {
  id         String   @id @default("singleton")
  lastLedger Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model SacMapping {
  id           String   @id @default(cuid())
  assetCode    String
  assetIssuer  String?
  assetType    String
  sacAddress   String   @unique
  firstSeenLedger Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([assetCode, assetIssuer])
  @@index([sacAddress])
  @@index([assetCode])
}

model SacTrustlineMapping {
  id                  String   @id @default(cuid())
  gAccount            String
  sacAddress          String
  assetCode           String
  assetIssuer         String?
  assetType           String   @default("credit_alphanum4")
  trustlineLimit      String   @default("0")
  isUnlimited         Boolean  @default(false)
  status              String   @default("active")
  transactionHash     String
  ledgerSequence      Int
  ledgerCloseTime     DateTime
  changeTrustOpLedger Int?
  changeTrustOpTxHash String?
  origin              String   @default("soroban")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([gAccount, sacAddress])
  @@index([gAccount])
  @@index([sacAddress])
  @@index([assetCode])
  @@index([status])
  @@index([ledgerSequence])
  @@index([changeTrustOpLedger])
}

model VerificationJob {
  id              String   @id @default(cuid())
  contractAddress String?
  toolchain       String   @default("soroban-cli@0.9.4")
  status          String   @default("pending")
  uploadedHash    String?
  onChainWasmHash String?
  compiledWasmHash String?
  matched         Boolean?
  errorMsg        String?
  logs            String?
  sourceFiles     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contractAddress])
  @@index([status])
}

model ContractState {
  id                 String   @id @default(cuid())
  contractAddress    String
  ledgerKey          String
  keyType            String
  status             String   @default("Live")
  liveUntilLedgerSeq Int?
  lastSeenLedger     Int
  restoredAtLedger   Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([contractAddress, ledgerKey])
  @@index([contractAddress])
  @@index([status])
  @@index([liveUntilLedgerSeq])
}

model RestorationLog {
  id              String   @id @default(cuid())
  transactionHash String   @unique
  sourceAccount   String
  ledgerSequence  Int
  ledgerCloseTime DateTime
  feeCharged      String?
  restoredKeys    Json
  createdAt       DateTime @default(now())

  @@index([sourceAccount])
  @@index([ledgerSequence])
}

model FailedItem {
  id          String   @id @default(cuid())
  itemType    String
  itemId      String
  ledger      Int
  rawXdr      String?
  errorMsg    String
  errorStack  String?
  context     Json?
  retryCount  Int      @default(0)
  dead        Boolean  @default(false)
  createdAt   DateTime @default(now())
  lastTriedAt DateTime @default(now())

  @@index([itemType, dead])
  @@index([ledger])
}

model ApiKey {
  id         String   @id @default(cuid())
  key        String   @unique
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
}

model ContractResourceMetric {
  id               String   @id @default(cuid())
  contractAddress  String
  transactionHash  String
  ledgerSequence   Int
  ledgerCloseTime  DateTime
  memoryUsageBytes Int
  cpuInstructions  Int
  storageFootprint Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([contractAddress, transactionHash])
  @@index([contractAddress])
  @@index([ledgerSequence])
}

model TranslationKey {
  id          String   @id @default(cuid())
  key         String   @unique
  defaultText String
  context     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations Translation[]

  @@index([key])
}

model Translation {
  id             String   @id @default(cuid())
  keyId          String
  language       String
  translatedText String
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  key TranslationKey @relation(fields: [keyId], references: [id])

  @@unique([keyId, language])
  @@index([language])
}
