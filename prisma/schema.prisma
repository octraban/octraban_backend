generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ledger {
  sequence     Int      @id
  hash         String   @unique
  closeTime    DateTime
  txCount      Int      @default(0)
  createdAt    DateTime @default(now())

  transactions Transaction[]
  events       Event[]

  @@index([sequence])
  @@index([closeTime])
}

model Contract {
  id                 String   @id @default(cuid())
  address            String   @unique
  name               String?
  description        String?
  abi                Json?
  functionSignatures Json?
  isToken            Boolean  @default(false)
  tokenSymbol        String?
  tokenName          String?
  tokenDecimals      Int?
  wasmHash           String?
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions Transaction[]
  events       Event[]
  wasmUpgrades WasmUpgradeHistory[]

  @@index([address])
}

model WasmUpgradeHistory {
  id              String   @id @default(cuid())
  contractAddress String
  previousHash    String?
  newHash         String
  ledgerSequence  Int
  ledgerCloseTime DateTime
  transactionHash String?
  createdAt       DateTime @default(now())

  contract Contract @relation(fields: [contractAddress], references: [address])

  @@index([contractAddress, ledgerSequence])
  @@index([ledgerSequence])
}

model Transaction {
  id               String   @id @default(cuid())
  hash             String   @unique
  ledgerSequence   Int
  ledgerCloseTime  DateTime
  sourceAccount    String
  contractAddress  String?
  functionName     String?
  functionArgs     Json?
  rawXdr           String
  status           String
  humanReadable    String?
  feeCharged       String?
  sorobanResources Json?
  failureReason    String?
  createdAt        DateTime @default(now())

  ledger   Ledger    @relation(fields: [ledgerSequence], references: [sequence])
  contract Contract? @relation(fields: [contractAddress], references: [address])
  events   Event[]

  @@index([hash])
  @@index([ledgerSequence])
  @@index([sourceAccount])
  @@index([contractAddress])
  @@index([status])
  @@index([contractAddress, ledgerSequence, id])
  @@index([sourceAccount, ledgerSequence, id])
  @@index([status, ledgerSequence, id])
  @@index([ledgerSequence, id])
}

model Event {
  id              String   @id @default(cuid())
  transactionHash String
  contractAddress String
  eventType       String
  topicSymbol     String?
  topics          Json
  data            Json
  decoded         Json?
  ledgerSequence  Int
  ledgerCloseTime DateTime
  createdAt       DateTime @default(now())

  ledger      Ledger      @relation(fields: [ledgerSequence], references: [sequence])
  transaction Transaction @relation(fields: [transactionHash], references: [hash])
  contract    Contract    @relation(fields: [contractAddress], references: [address])

  @@index([transactionHash])
  @@index([contractAddress])
  @@index([eventType])
  @@index([topicSymbol])
  @@index([ledgerSequence])
  @@index([contractAddress, topicSymbol])
  @@index([contractAddress, ledgerSequence, id])
  @@index([contractAddress, eventType, ledgerSequence])
}

model EventDefinition {
  id              String   @id @default(cuid())
  contractAddress String
  topicSymbol     String
  humanTemplate   String
  submittedBy     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([contractAddress, topicSymbol])
  @@index([contractAddress])
}

model SessionAuthorization {
  id                String   @id @default(cuid())
  eventId           String   @unique
  contractAddress   String
  hotSigner         String?
  authorizationType String
  startLedger       Int
  expiryLedger      Int
  allocatedBlocks   Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([contractAddress])
  @@index([expiryLedger])
}

model IndexerState {
  id         String   @id @default("singleton")
  lastLedger Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model SacMapping {
  id           String   @id @default(cuid())
  assetCode    String
  assetIssuer  String?
  assetType    String
  sacAddress   String   @unique
  firstSeenLedger Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([assetCode, assetIssuer])
  @@index([sacAddress])
  @@index([assetCode])
}

model SacTrustlineMapping {
  id                  String   @id @default(cuid())
  gAccount            String
  sacAddress          String
  assetCode           String
  assetIssuer         String?
  assetType           String   @default("credit_alphanum4")
  trustlineLimit      String   @default("0")
  isUnlimited         Boolean  @default(false)
  status              String   @default("active")
  transactionHash     String
  ledgerSequence      Int
  ledgerCloseTime     DateTime
  changeTrustOpLedger Int?
  changeTrustOpTxHash String?
  origin              String   @default("soroban")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([gAccount, sacAddress])
  @@index([gAccount])
  @@index([sacAddress])
  @@index([assetCode])
  @@index([status])
  @@index([ledgerSequence])
  @@index([changeTrustOpLedger])
}

model VerificationJob {
  id              String   @id @default(cuid())
  contractAddress String?
  toolchain       String   @default("soroban-cli@0.9.4")
  status          String   @default("pending")
  uploadedHash    String?
  onChainWasmHash String?
  compiledWasmHash String?
  matched         Boolean?
  errorMsg        String?
  logs            String?
  sourceFiles     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contractAddress])
  @@index([status])
}

model ContractState {
  id                 String   @id @default(cuid())
  contractAddress    String
  ledgerKey          String
  keyType            String
  status             String   @default("Live")
  liveUntilLedgerSeq Int?
  lastSeenLedger     Int
  restoredAtLedger   Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([contractAddress, ledgerKey])
  @@index([contractAddress])
  @@index([status])
  @@index([liveUntilLedgerSeq])
}

model RestorationLog {
  id              String   @id @default(cuid())
  transactionHash String   @unique
  sourceAccount   String
  ledgerSequence  Int
  ledgerCloseTime DateTime
  feeCharged      String?
  restoredKeys    Json
  createdAt       DateTime @default(now())

  @@index([sourceAccount])
  @@index([ledgerSequence])
}

model FailedItem {
  id          String   @id @default(cuid())
  itemType    String
  itemId      String
  ledger      Int
  rawXdr      String?
  errorMsg    String
  errorStack  String?
  context     Json?
  retryCount  Int      @default(0)
  dead        Boolean  @default(false)
  createdAt   DateTime @default(now())
  lastTriedAt DateTime @default(now())

  @@index([itemType, dead])
  @@index([ledger])
}

model ApiKey {
  id         String   @id @default(cuid())
  key        String   @unique
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
}

model ContractResourceMetric {
  id               String   @id @default(cuid())
  contractAddress  String
  transactionHash  String
  ledgerSequence   Int
  ledgerCloseTime  DateTime
  memoryUsageBytes Int
  cpuInstructions  Int
  storageFootprint Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([contractAddress, transactionHash])
  @@index([contractAddress])
  @@index([ledgerSequence])
}

model TranslationKey {
  id          String   @id @default(cuid())
  key         String   @unique
  defaultText String
  context     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations Translation[]

  @@index([key])
}

model Translation {
  id             String   @id @default(cuid())
  keyId          String
  language       String
  translatedText String
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  key TranslationKey @relation(fields: [keyId], references: [id])

  @@unique([keyId, language])
  @@index([language])
}

model WalletUser {
  id          String   @id @default(uuid())
  address     String   @unique @db.VarChar(56)
  role        String   @default("user") @db.VarChar(20)
  tier        String   @default("free") @db.VarChar(20)
  email       String?  @db.VarChar(255)
  displayName String?  @map("display_name") @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url")
  metadata    Json     @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  isMultiSig  Boolean  @default(false) @map("is_multi_sig")
  createdAt   DateTime @default(now()) @map("created_at")
  lastLogin   DateTime? @map("last_login")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions AuthSession[]
  events   AuthEvent[]

  @@map("wallet_users")
}

model AuthSession {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  tokenHash          String    @map("token_hash") @db.VarChar(64)
  refreshTokenHash   String?   @map("refresh_token_hash") @db.VarChar(64)
  deviceInfo         Json?     @map("device_info")
  appId              String?   @map("app_id") @db.VarChar(50)
  isActive           Boolean   @default(true) @map("is_active")
  expiresAt          DateTime  @map("expires_at")
  lastActivity       DateTime  @default(now()) @map("last_activity")
  revokedAt          DateTime? @map("revoked_at")
  revocationReason   String?   @map("revocation_reason") @db.VarChar(50)
  createdAt          DateTime  @default(now()) @map("created_at")

  user   WalletUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  events AuthEvent[]

  @@index([userId, isActive])
  @@index([tokenHash])
  @@map("auth_sessions")
}

model AuthEvent {
  id        BigInt   @id @default(autoincrement())
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id")
  eventType String   @map("event_type") @db.VarChar(50)
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user    WalletUser?  @relation(fields: [userId], references: [id])
  session AuthSession? @relation(fields: [sessionId], references: [id])

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("auth_events")
}

model MultiSigWallet {
  id            String   @id @default(uuid())
  walletAddress String   @unique @map("wallet_address") @db.VarChar(56)
  signers       Json
  threshold     Int
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("multi_sig_wallets")
}

model OAuthApp {
  id           String   @id @default(uuid())
  clientId     String   @unique @map("client_id")
  clientSecret String   @map("client_secret")
  name         String
  redirectUris Json     @map("redirect_uris")
  scopes       Json     @default("[]")
  ownerId      String?  @map("owner_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("oauth_apps")
}

model OAuthCode {
  id          String   @id @default(uuid())
  code        String   @unique
  clientId    String   @map("client_id")
  userId      String   @map("user_id")
  redirectUri String   @map("redirect_uri")
  scopes      Json     @default("[]")
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([code])
  @@map("oauth_codes")
}

model AuthWebhook {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  url       String
  events    Json
  secret    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("auth_webhooks")
}
